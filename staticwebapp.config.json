{
  "globalHeaders": {
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "routes": [
    {
      "route": "/sponsorship",
      "rewrite": "/sponsorship.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/Images - Copy/*", "/*.css", "/*.png", "/*.jpg", "/*.jpeg", "/*.gif", "/*.webp", "/*.ico"]
  }
}
